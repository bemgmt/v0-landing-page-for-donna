{
  "name": "donna",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "validate-env": "node scripts/validate-env.mjs",
    "dev": "npm run validate-env && next dev",
    "build": "npm run validate-env && next build",
    "vercel-build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:serial": "jest --runInBand",
    "test:ci:serial": "jest --runInBand --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep=@smoke --project=chromium --workers=1",
    "test:e2e:ci": "playwright test --workers=1",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "health-check": "node scripts/health-check.mjs",
    "health-check:resilient": "node scripts/resilient-health-check.mjs",
    "test:php": "powershell -ExecutionPolicy Bypass -File scripts/run-php-tests.ps1",
    "test:php:docker": "powershell -ExecutionPolicy Bypass -File scripts/run-php-tests.ps1 -Method docker",
    "test:php-responses": "node scripts/validate-php-responses.mjs",
    "test:php-schemas": "node scripts/ci-php-schema-check.mjs",
    "test:ws2": "node scripts/ws2-contract-test.mjs",
    "test:ws2-auth": "node scripts/ws2-ws-auth-smoke.mjs",
    "test:ws2-audio": "node scripts/ws2-audio-helpers-test.mjs",
    "test:ws2:all": "npm run -s test:ws2 && npm run -s test:ws2-audio",
    "analyze": "ANALYZE=true next build",
    "test:perf": "node scripts/perf-bundle-size.mjs && playwright test --grep=@perf --project=chromium",
    "test:perf:ci": "npm run -s test:perf",
    "ci": "npm run -s lint && npm run -s test:ci:serial && npm run -s test:ws2:all && npm run -s test:php-schemas && npm run -s test:perf:ci",
    "test:security:smoke": "node scripts/security-smoke.mjs",
    "test:fanout:smoke": "node scripts/fanout-smoke.mjs",
    "pre-pr-validation": "node scripts/pre-pr-validation.mjs",
    "production-health-check": "node scripts/production-health-check.mjs",
    "validate-production-env": "node scripts/validate-production-env.mjs",
    "sentry:sourcemaps": "sentry-cli sourcemaps upload --release=$npm_package_version .next/static/chunks/",
    "sentry:release": "sentry-cli releases new $npm_package_version && sentry-cli releases set-commits $npm_package_version --auto",
    "data-room:pdf": "node scripts/export-data-room-pdfs.mjs"
  },
  "dependencies": {
    "@floating-ui/core": "1.7.3",
    "@floating-ui/dom": "1.7.4",
    "@floating-ui/utils": "0.2.10",
    "@openai/agents": "^0.1.1",
    "@openai/agents-realtime": "^0.1.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^7.120.4",
    "@sentry/profiling-node": "^1.3.5",
    "@supabase/supabase-js": "^2.57.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.2.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.12",
    "geist": "^1.5.1",
    "googleapis": "^159.0.0",
    "input-otp": "^1.4.2",
    "isomorphic-dompurify": "^2.26.0",
    "lucide-react": "^0.542.0",
    "motion-dom": "^12.24.11",
    "motion-utils": "^12.24.10",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "openai": "^5.20.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.0",
    "react-resizable-panels": "^3.0.5",
    "recharts": "^3.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "web-vitals": "^4.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.32",
    "@playwright/test": "^1.55.0",
    "@sentry/cli": "^2.20.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "chalk": "^5.6.2",
    "eslint": "^8",
    "eslint-config-next": "^14.2.32",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "md-to-pdf": "^5.2.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": ">=9.0.0"
  }
}
