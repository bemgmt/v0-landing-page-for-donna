# DONNA Logic widget (browser — same exposure as any embed; rotate in Chatbot Control if leaked)
NEXT_PUBLIC_DONNA_API_BASE=https://app.bemdonna.com
NEXT_PUBLIC_DONNA_WIDGET_TOKEN=wt_4b5f919da340f0438b9d7a9b9a7035116f38c703d5a815c7ff858a88ceaa5ddf
NEXT_PUBLIC_DONNA_USER_PROFILE=general
NEXT_PUBLIC_DONNA_GREETING="Hi! I'm DONNA, your AI Operations Assistant. How can I help you today?"

# Site URL for metadata, Stripe return URLs, stable PWA manifest `id`, and Supabase auth redirects
# (magic link + OAuth `redirectTo` / `emailRedirectTo`). Required in production so sign-in links return to this host (no trailing slash).
# Set per deployment (e.g. https://aidonna.co on that host). Local dev: http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://bemdonna.com

# Stripe Checkout (subscriptions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Stable plan identifiers: set each recurring Price’s “Lookup key” in Stripe Dashboard (Product → Price)
# to match these defaults, OR override via env. Lookup keys do not churn when a price is recreated.
#   - DONNA Early Adopter (Core) $500/mo  → core_cloud_workspace_500
#   - DONNA Early Adopter (Full Access) $1000/mo → full_toolkit_1000
# Optional overrides (defaults match lib/billing/plan-seats.ts):
# STRIPE_PRICE_LOOKUP_CORE=core_cloud_workspace_500
# STRIPE_PRICE_LOOKUP_FULL=full_toolkit_1000
#
# After setting lookup_key on a new Price, re-sync existing subscribers (Stripe CLI: trigger customer.subscription.updated,
# or toggle subscription metadata once) so webhooks repopulate billing_subscription_items.price_lookup_key.
#
# Legacy fallback (Core only): if no active price matches STRIPE_PRICE_LOOKUP_CORE, checkout uses this id:
# STRIPE_PRICE_ID=price_...

# Stripe Pricing Table (landing #pricing — client embed; safe to expose publishable key)
# Create a Pricing Table in Stripe Dashboard → Product catalog → Pricing tables, then paste id + pk_live or pk_test.
# NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=prctbl_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase (portal auth + data + storage)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only: webhooks / privileged scripts

# Optional: OpenAI for Can DONNA + support chat AI replies
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: Sanity CMS (portal copy / site settings)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
